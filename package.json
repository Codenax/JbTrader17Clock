{
  "name": "jbtrader17-clock",
  "version": "1.0.0",
  "description": "Professional Trading Clock",
  "author": "JbTrader17",

  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },

  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },

  "dependencies": {
    "electron-store": "^11.0.2"
  },

  "build": {
    "appId": "com.jbtrader.clock",
    "productName": "JbTrader17 Clock",

    "asar": true,

    "files": [
      "**/*"
    ],
 
    "win": {
      "target": [
        "nsis",
        "portable"
        ],
       "icon": "iconRound2.ico"
    },

    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "iconRound2.ico",
      "uninstallerIcon": "iconRound2.ico",
      "artifactName": "JbTrader17-Setup-${version}.exe"
    },

    "compression": "maximum"
  }
}